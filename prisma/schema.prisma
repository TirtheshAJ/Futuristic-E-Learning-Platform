// Prisma Schema for CodeStreak Academy
// This is an alternative to raw SQL - modern ORM approach

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USER & AUTH ====================

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String    @map("password_hash")
  fullName               String    @map("full_name")
  role                   UserRole  @default(STUDENT)
  isEmailVerified        Boolean   @default(false) @map("is_email_verified")
  emailVerificationToken String?   @map("email_verification_token")
  resetPasswordToken     String?   @map("reset_password_token")
  resetPasswordExpires   DateTime? @map("reset_password_expires")
  oauthProvider          String?   @map("oauth_provider")
  oauthId                String?   @map("oauth_id")
  avatarUrl              String?   @map("avatar_url")
  themePreference        Theme     @default(DARK) @map("theme_preference")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  lastLogin              DateTime? @map("last_login")

  // Relations
  courses           Course[]
  progress          UserProgress[]
  quizAttempts      QuizAttempt[]
  streak            UserStreak?
  xp                UserXP?
  coins             UserCoins?
  coinTransactions  CoinTransaction[]
  achievements      UserAchievement[]
  courseUnlocks     CourseUnlock[]
  learningAnalytics LearningAnalytics[]

  @@index([email])
  @@index([oauthProvider, oauthId])
  @@index([role])
  @@map("users")
}

enum UserRole {
  STUDENT
  ADMIN
  INSTRUCTOR
}

enum Theme {
  DARK
  LIGHT
}

// ==================== COURSES & CONTENT ====================

model Course {
  id             String       @id @default(uuid())
  title          String
  slug           String       @unique
  description    String?      @db.Text
  icon           String?
  difficulty     Difficulty
  estimatedHours Int          @default(0) @map("estimated_hours")
  coinReward     Int          @default(0) @map("coin_reward")
  xpReward       Int          @default(0) @map("xp_reward")
  isLocked       Boolean      @default(false) @map("is_locked")
  unlockCost     Int          @default(0) @map("unlock_cost")
  orderIndex     Int          @default(0) @map("order_index")
  isActive       Boolean      @default(true) @map("is_active")
  createdById    String?      @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  createdBy     User?           @relation(fields: [createdById], references: [id])
  lectures      Lecture[]
  quizzes       Quiz[]
  progress      UserProgress[]
  unlocks       CourseUnlock[]

  @@index([slug])
  @@index([difficulty])
  @@index([isActive])
  @@index([orderIndex])
  @@map("courses")
}

enum Difficulty {
  BEGINNER      @map("Beginner")
  INTERMEDIATE  @map("Intermediate")
  ADVANCED      @map("Advanced")
}

model Lecture {
  id             String      @id @default(uuid())
  courseId       String      @map("course_id")
  title          String
  description    String?     @db.Text
  contentType    ContentType @map("content_type")
  contentUrl     String?     @map("content_url") @db.Text
  durationMinutes Int        @default(0) @map("duration_minutes")
  xpReward       Int         @default(50) @map("xp_reward")
  orderIndex     Int         @default(0) @map("order_index")
  isActive       Boolean     @default(true) @map("is_active")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relations
  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress UserProgress[]

  @@index([courseId])
  @@index([isActive])
  @@index([courseId, orderIndex])
  @@map("lectures")
}

enum ContentType {
  VIDEO
  PDF
  TEXT
  INTERACTIVE
}

// ==================== PROGRESS TRACKING ====================

model UserProgress {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  courseId           String    @map("course_id")
  lectureId          String    @map("lecture_id")
  status             ProgressStatus @default(IN_PROGRESS)
  progressPercentage Int       @default(0) @map("progress_percentage")
  timeSpentMinutes   Int       @default(0) @map("time_spent_minutes")
  lastAccessed       DateTime  @default(now()) @map("last_accessed")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lecture Lecture @relation(fields: [lectureId], references: [id], onDelete: Cascade)

  @@unique([userId, lectureId])
  @@index([userId])
  @@index([courseId])
  @@index([userId, courseId])
  @@index([status])
  @@map("user_progress")
}

enum ProgressStatus {
  NOT_STARTED   @map("not_started")
  IN_PROGRESS   @map("in_progress")
  COMPLETED     @map("completed")
}

// ==================== QUIZ SYSTEM ====================

model Quiz {
  id             String   @id @default(uuid())
  courseId       String   @map("course_id")
  title          String
  description    String?  @db.Text
  durationMinutes Int     @default(30) @map("duration_minutes")
  passingScore   Int      @default(70) @map("passing_score")
  totalQuestions Int      @default(0) @map("total_questions")
  coinReward     Int      @default(100) @map("coin_reward")
  xpReward       Int      @default(200) @map("xp_reward")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([courseId])
  @@index([isActive])
  @@map("quizzes")
}

model Question {
  id           String   @id @default(uuid())
  quizId       String   @map("quiz_id")
  questionText String   @map("question_text") @db.Text
  questionType String   @default("multiple_choice") @map("question_type")
  options      Json     // Array of {text: string, isCorrect: boolean}
  correctAnswer String  @map("correct_answer") @db.Text
  explanation  String?  @db.Text
  points       Int      @default(10)
  orderIndex   Int      @default(0) @map("order_index")
  createdAt    DateTime @default(now()) @map("created_at")

  // Relations
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([quizId, orderIndex])
  @@map("questions")
}

model QuizAttempt {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  quizId           String    @map("quiz_id")
  score            Int       @default(0)
  totalPoints      Int       @default(0) @map("total_points")
  percentage       Decimal   @default(0) @db.Decimal(5, 2)
  answers          Json?     // {questionId: selectedAnswer}
  timeTakenSeconds Int       @default(0) @map("time_taken_seconds")
  passed           Boolean   @default(false)
  coinsEarned      Int       @default(0) @map("coins_earned")
  xpEarned         Int       @default(0) @map("xp_earned")
  startedAt        DateTime  @default(now()) @map("started_at")
  submittedAt      DateTime? @map("submitted_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
  @@index([submittedAt])
  @@map("quiz_attempts")
}

// ==================== GAMIFICATION ====================

model UserStreak {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  currentStreak    Int      @default(0) @map("current_streak")
  longestStreak    Int      @default(0) @map("longest_streak")
  lastActivityDate DateTime? @map("last_activity_date") @db.Date
  weeklyStreak     Int      @default(0) @map("weekly_streak")
  totalActiveDays  Int      @default(0) @map("total_active_days")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([currentStreak])
  @@map("user_streaks")
}

model UserXP {
  userId        String   @id @map("user_id")
  currentXp     Int      @default(0) @map("current_xp")
  level         Int      @default(1)
  totalXpEarned Int      @default(0) @map("total_xp_earned")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
  @@index([totalXpEarned])
  @@map("user_xp")
}

model UserCoins {
  userId         String   @id @map("user_id")
  balance        Int      @default(0)
  lifetimeEarned Int      @default(0) @map("lifetime_earned")
  lifetimeSpent  Int      @default(0) @map("lifetime_spent")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([balance])
  @@map("user_coins")
}

model CoinTransaction {
  id              String          @id @default(uuid())
  userId          String          @map("user_id")
  amount          Int
  transactionType TransactionType @map("transaction_type")
  source          String
  referenceId     String?         @map("reference_id")
  description     String?         @db.Text
  balanceAfter    Int?            @map("balance_after")
  createdAt       DateTime        @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("coin_transactions")
}

enum TransactionType {
  EARNED
  SPENT
  REFUND
}

model Achievement {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  icon        String?
  rarity      Rarity
  criteria    Json      // {type: string, value: number}
  coinReward  Int       @default(0) @map("coin_reward")
  xpReward    Int       @default(0) @map("xp_reward")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  userAchievements UserAchievement[]

  @@index([rarity])
  @@index([isActive])
  @@map("achievements")
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  achievementId String   @map("achievement_id")
  earnedAt      DateTime @default(now()) @map("earned_at")

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([earnedAt])
  @@map("user_achievements")
}

// ==================== COURSE UNLOCKS ====================

model CourseUnlock {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  courseId   String   @map("course_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("course_unlocks")
}

// ==================== ANALYTICS ====================

model LearningAnalytics {
  id                String   @id @default(uuid())
  userId            String   @map("user_id")
  date              DateTime @db.Date
  totalTimeMinutes  Int      @default(0) @map("total_time_minutes")
  lecturesCompleted Int      @default(0) @map("lectures_completed")
  quizzesAttempted  Int      @default(0) @map("quizzes_attempted")
  xpEarned          Int      @default(0) @map("xp_earned")
  coinsEarned       Int      @default(0) @map("coins_earned")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date])
  @@map("learning_analytics")
}
